{
  "name": "@grepture/proxy",
  "version": "0.1.0",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "dev:cloud": "GREPTURE_MODE=cloud GREPTURE_PLUGINS=./plugins/pro-actions/src/index.ts bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "start:cloud": "GREPTURE_MODE=cloud GREPTURE_PLUGINS=./plugins/pro-actions/src/index.ts bun run src/index.ts",
    "build:oss": "bun run scripts/build-oss.ts",
    "typecheck": "tsc --noEmit",
    "pm2": "pm2 start --interpreter bun src/index.ts --name grepture-proxy",
    "pm2:stop": "pm2 stop grepture-proxy",
    "pm2:logs": "pm2 logs grepture-proxy",
    "pm2:restart": "pm2 restart grepture-proxy"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "@upstash/redis": "^1.34.0",
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@types/bun": "^1.2.0",
    "typescript": "^5.9.3"
  }
}
